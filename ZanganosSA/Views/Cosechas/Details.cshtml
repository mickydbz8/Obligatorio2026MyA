@model ZanganosSA.Models.Cosecha

@{
    ViewData["Title"] = "Detalles de Cosecha";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-eye text-warning"></i> Detalles de Cosecha</h2>
            <dl class="row">
                <dt class="col-sm-4 fw-bold">Fecha de Cosecha</dt>
                <dd class="col-sm-8">@Model.FechaCosecha.ToString("dd/MM/yyyy")</dd>
                <dt class="col-sm-4 fw-bold">Peso Total Estimado</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.PesoTotalEstimado) kg</dd>
                <dt class="col-sm-4 fw-bold">Apiario</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Apiario.Nombre)</dd>
            </dl>
            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning fw-bold"><i class="bi bi-pencil"></i> Editar</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver al listado</a>
            </div>
        </div>
    </div>
</div>
