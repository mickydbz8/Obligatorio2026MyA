@model IEnumerable<ZanganosSA.Models.Barril>

@{
    ViewData["Title"] = "Barriles de Exportación";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-droplet-fill text-primary"></i> Barriles de Exportación</h1>
    <a asp-action="Create" class="btn btn-warning fw-bold"><i class="bi bi-plus-circle"></i> Nuevo Barril</a>
</div>

<div class="table-responsive">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Código de Lote</th>
            <th>Peso Neto (kg)</th>
            <th>Fecha de Envasado</th>
            <th>Cosecha N°</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@Html.DisplayFor(modelItem => item.CodigoLote)</strong></td>
                <td>@Html.DisplayFor(modelItem => item.PesoNeto) kg</td>
                <td>@item.FechaEnvasado.ToString("dd/MM/yyyy")</td>
                <td>#@Html.DisplayFor(modelItem => item.Cosecha.Id)</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
