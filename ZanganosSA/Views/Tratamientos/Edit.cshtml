@model ZanganosSA.Models.Tratamiento

@{
    ViewData["Title"] = "Editar Tratamiento";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-pencil text-warning"></i> Editar Tratamiento Sanitario</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Medicamento" class="form-label fw-bold">Medicamento</label>
                    <input asp-for="Medicamento" class="form-control" />
                    <span asp-validation-for="Medicamento" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Dosis" class="form-label fw-bold">Dosis</label>
                    <input asp-for="Dosis" class="form-control" />
                    <span asp-validation-for="Dosis" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FechaInicio" class="form-label fw-bold">Fecha de Inicio</label>
                    <input asp-for="FechaInicio" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="DuracionDias" class="form-label fw-bold">Duración (días)</label>
                    <input asp-for="DuracionDias" class="form-control" type="number" min="1" />
                    <span asp-validation-for="DuracionDias" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Estado" class="form-label fw-bold">Estado</label>
                    <select asp-for="Estado" class="form-select">
                        <option>En Curso</option>
                        <option>Finalizado</option>
                        <option>Pendiente</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ColmenaId" class="form-label fw-bold">Colmena</label>
                    <select asp-for="ColmenaId" class="form-select" asp-items="ViewBag.ColmenaId"></select>
                    <span asp-validation-for="ColmenaId" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
