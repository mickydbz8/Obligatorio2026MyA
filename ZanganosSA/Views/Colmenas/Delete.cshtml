@model ZanganosSA.Models.Colmena

@{
    ViewData["Title"] = "Eliminar Colmena";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4 border-danger">
            <h2 class="mb-2 text-danger"><i class="bi bi-exclamation-triangle"></i> Eliminar Colmena</h2>
            <p class="text-muted mb-4">¿Estás seguro de que deseas eliminar esta colmena? Esta acción no se puede deshacer.</p>
            <dl class="row">
                <dt class="col-sm-4 fw-bold">Identificador</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Identificador)</dd>
                <dt class="col-sm-4 fw-bold">Estado General</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.EstadoGeneral)</dd>
                <dt class="col-sm-4 fw-bold">Estado de la Reina</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.EstadoReina)</dd>
                <dt class="col-sm-4 fw-bold">Apiario</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Apiario.Nombre)</dd>
            </dl>
            <form asp-action="Delete" class="d-flex gap-2 mt-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger fw-bold"><i class="bi bi-trash"></i> Sí, eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
            </form>
        </div>
    </div>
</div>
