@model ZanganosSA.Models.HomeViewModel

@{
    ViewData["Title"] = "Dashboard - ZÃ¡nganos SA";
}

<div class="text-center mb-4">
    <h1 class="display-4 text-warning fw-bold">ðŸ¯ SGAI - ZÃ¡nganos SA</h1>
    <p class="lead">Sistema de GestiÃ³n ApÃ­cola Integral</p>
    <div class="d-flex justify-content-center gap-3">
        <span class="badge bg-primary fs-6">Apiarios: @Model.TotalApiarios</span>
        <span class="badge bg-success fs-6">Colmenas: @Model.TotalColmenas</span>
