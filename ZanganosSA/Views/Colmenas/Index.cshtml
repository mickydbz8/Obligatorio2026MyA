@model IEnumerable<ZanganosSA.Models.Colmena>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Identificador)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstadoGeneral)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstadoReina)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UltimaInspeccion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Apiario)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Identificador)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EstadoGeneral)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EstadoReina)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UltimaInspeccion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Apiario.Nombre)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
