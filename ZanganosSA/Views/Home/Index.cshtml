<!-- Panel de Alertas Inteligentes -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white fw-bold">
                <i class="bi bi-exclamation-triangle-fill"></i> Alertas Sanitarias y de Mantenimiento Activas
            </div>
            <ul class="list-group list-group-flush">
                @if (Model.TratamientosActivos.Any())
                {
                    @foreach (var trat in Model.TratamientosActivos)
                    {
                        var fechaFin = trat.FechaInicio.AddDays(trat.DuracionDias);
                        var diasRestantes = (int)(fechaFin - DateTime.Now).TotalDays;
                        string alertClass = diasRestantes <= 2 ? "list-group-item-danger" : "list-group-item-warning";

                        <li class="list-group-item @alertClass d-flex justify-content-between align-items-center">
                            <span>
                                <strong>Colmena:</strong> @trat.Colmena?.Identificador | 
                                <strong>Medicamento:</strong> @trat.Medicamento 
                                (Fin: @fechaFin.ToShortDateString())
                            </span>
                            @if (diasRestantes < 0)
                            {
                                <span class="badge bg-danger rounded-pill">VENCIDO (@Math.Abs(diasRestantes) dÃ­as)</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill">Faltan @diasRestantes dÃ­as</span>
                            }
                        </li>
                    }
                }
                else
                {
                    <li class="list-group-item text-muted">No hay tratamientos activos en este momento.</li>
                }
                <!-- Alerta Simulada de AlimentaciÃ³n -->
                <li class="list-group-item list-group-item-info d-flex justify-content-between align-items-center">
                    <span>
                        <strong>Recordatorio:</strong> Revisar nivel de jarabe en Apiario Principal (AlimentaciÃ³n Suplementaria).
                    </span>
                    <span class="badge bg-info text-dark rounded-pill">Sugerencia</span>
                </li>
            </ul>
        </div>
    </div>
</div>

