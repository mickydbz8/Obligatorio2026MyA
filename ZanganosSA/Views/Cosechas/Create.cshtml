@model ZanganosSA.Models.Cosecha

@{
    ViewData["Title"] = "Nueva Cosecha";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-plus-circle text-warning"></i> Nueva Cosecha</h2>
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="FechaCosecha" class="form-label fw-bold">Fecha de Cosecha</label>
                    <input asp-for="FechaCosecha" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaCosecha" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="PesoTotalEstimado" class="form-label fw-bold">Peso Total Estimado (kg)</label>
                    <input asp-for="PesoTotalEstimado" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="PesoTotalEstimado" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ApiarioId" class="form-label fw-bold">Apiario</label>
                    <select asp-for="ApiarioId" class="form-select" asp-items="ViewBag.ApiarioId">
                        <option value="">-- Seleccionar apiario --</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
