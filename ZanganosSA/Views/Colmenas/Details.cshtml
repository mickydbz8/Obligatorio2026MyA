@model ZanganosSA.Models.Colmena

@{
    ViewData["Title"] = "Detalles de Colmena";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-eye text-warning"></i> Detalles de Colmena</h2>
            <dl class="row">
                <dt class="col-sm-4 fw-bold">Identificador</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Identificador)</dd>
                <dt class="col-sm-4 fw-bold">Estado General</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.EstadoGeneral)</dd>
                <dt class="col-sm-4 fw-bold">Estado de la Reina</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.EstadoReina)</dd>
                <dt class="col-sm-4 fw-bold">Última Inspección</dt>
                <dd class="col-sm-8">@Model.UltimaInspeccion.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-4 fw-bold">Apiario</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Apiario.Nombre)</dd>
            </dl>
            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning fw-bold"><i class="bi bi-pencil"></i> Editar</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver al listado</a>
            </div>
        </div>
    </div>
</div>
