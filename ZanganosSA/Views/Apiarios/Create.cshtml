@model ZanganosSA.Models.Apiario

@{
    ViewData["Title"] = "Nuevo Apiario";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-plus-circle text-warning"></i> Nuevo Apiario</h2>
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-bold">Nombre del Apiario</label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Apiario Norte" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="UbicacionGps" class="form-label fw-bold">Ubicación GPS</label>
                    <input asp-for="UbicacionGps" class="form-control" placeholder="Ej: -34.9011, -56.1645" />
                    <span asp-validation-for="UbicacionGps" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="SeccionalPolicial" class="form-label fw-bold">Seccional Policial</label>
                    <input asp-for="SeccionalPolicial" class="form-control" placeholder="Ej: Seccional 3" />
                    <span asp-validation-for="SeccionalPolicial" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
