@model ZanganosSA.Models.Colmena

@{
    ViewData["Title"] = "Nueva Colmena";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-plus-circle text-warning"></i> Nueva Colmena</h2>
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="Identificador" class="form-label fw-bold">Identificador</label>
                    <input asp-for="Identificador" class="form-control" placeholder="Ej: COL-001" />
                    <span asp-validation-for="Identificador" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EstadoGeneral" class="form-label fw-bold">Estado General</label>
                    <select asp-for="EstadoGeneral" class="form-select">
                        <option value="">-- Seleccionar estado --</option>
                        <option>Fuerte</option>
                        <option>Normal</option>
                        <option>Débil</option>
                    </select>
                    <span asp-validation-for="EstadoGeneral" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EstadoReina" class="form-label fw-bold">Estado de la Reina</label>
                    <select asp-for="EstadoReina" class="form-select">
                        <option value="">-- Seleccionar estado --</option>
                        <option>Joven</option>
                        <option>Vieja</option>
                        <option>Sin Reina</option>
                    </select>
                    <span asp-validation-for="EstadoReina" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="UltimaInspeccion" class="form-label fw-bold">Última Inspección</label>
                    <input asp-for="UltimaInspeccion" class="form-control" type="datetime-local" />
                    <span asp-validation-for="UltimaInspeccion" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ApiarioId" class="form-label fw-bold">Apiario</label>
                    <select asp-for="ApiarioId" class="form-select" asp-items="ViewBag.ApiarioId">
                        <option value="">-- Seleccionar apiario --</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
