@model ZanganosSA.Models.Barril

@{
    ViewData["Title"] = "Eliminar Barril";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4 border-danger">
            <h2 class="mb-2 text-danger"><i class="bi bi-exclamation-triangle"></i> Eliminar Barril</h2>
            <p class="text-muted mb-4">¿Estás seguro de que deseas eliminar este barril? Esta acción no se puede deshacer.</p>
            <dl class="row">
                <dt class="col-sm-4 fw-bold">Código de Lote</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.CodigoLote)</dd>
                <dt class="col-sm-4 fw-bold">Peso Neto</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.PesoNeto) kg</dd>
                <dt class="col-sm-4 fw-bold">Fecha de Envasado</dt>
                <dd class="col-sm-8">@Model.FechaEnvasado.ToString("dd/MM/yyyy")</dd>
            </dl>
            <form asp-action="Delete" class="d-flex gap-2 mt-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger fw-bold"><i class="bi bi-trash"></i> Sí, eliminar</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
            </form>
        </div>
    </div>
</div>
