@model ZanganosSA.Models.Colmena

@{
    ViewData["Title"] = "Editar Colmena";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-pencil text-warning"></i> Editar Colmena</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Identificador" class="form-label fw-bold">Identificador</label>
                    <input asp-for="Identificador" class="form-control" />
                    <span asp-validation-for="Identificador" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EstadoGeneral" class="form-label fw-bold">Estado General</label>
                    <select asp-for="EstadoGeneral" class="form-select">
                        <option>Excelente</option>
                        <option>Buena</option>
                        <option>Regular</option>
                        <option>Mala</option>
                    </select>
                    <span asp-validation-for="EstadoGeneral" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EstadoReina" class="form-label fw-bold">Estado de la Reina</label>
                    <select asp-for="EstadoReina" class="form-select">
                        <option>Joven</option>
                        <option>Vieja</option>
                        <option>Sin Reina</option>
                    </select>
                    <span asp-validation-for="EstadoReina" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="UltimaInspeccion" class="form-label fw-bold">Última Inspección</label>
                    <input asp-for="UltimaInspeccion" class="form-control" type="datetime-local" />
                    <span asp-validation-for="UltimaInspeccion" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ApiarioId" class="form-label fw-bold">Apiario</label>
                    <select asp-for="ApiarioId" class="form-select" asp-items="ViewBag.ApiarioId"></select>
                    <span asp-validation-for="ApiarioId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FechaProximaAlimentacion" class="form-label fw-bold"><i class="bi bi-bell-fill text-warning"></i> Próxima Alimentación Suplementaria</label>
                    <input asp-for="FechaProximaAlimentacion" class="form-control" type="date" />
                    <span class="form-text text-muted">Dejar vacío si no corresponde. El sistema alertará 48hs antes.</span>
                    <span asp-validation-for="FechaProximaAlimentacion" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="CostoMantenimiento" class="form-label fw-bold"><i class="bi bi-cash-stack text-success"></i> Costo de Mantenimiento ($)</label>
                    <input asp-for="CostoMantenimiento" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="CostoMantenimiento" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
