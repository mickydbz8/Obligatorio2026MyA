@model IEnumerable<ZanganosSA.Models.Colmena>

@{
    ViewData["Title"] = "Colmenas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-box-seam text-warning"></i> Colmenas</h1>
    <a asp-action="Create" class="btn btn-warning fw-bold"><i class="bi bi-plus-circle"></i> Nueva Colmena</a>
</div>

<div class="table-responsive">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Identificador</th>
            <th>Estado General</th>
            <th>Estado de Reina</th>
            <th>Última Inspección</th>
            <th>Apiario</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@Html.DisplayFor(modelItem => item.Identificador)</strong></td>
                <td>
                    @{
                        string badgeClass = item.EstadoGeneral == "Fuerte" ? "bg-success" : (item.EstadoGeneral == "Débil" ? "bg-danger" : "bg-warning text-dark");
                    }
                    <span class="badge @badgeClass">@Html.DisplayFor(modelItem => item.EstadoGeneral)</span>
                </td>
                <td>@Html.DisplayFor(modelItem => item.EstadoReina)</td>
                <td>@item.UltimaInspeccion.ToString("dd/MM/yyyy")</td>
                <td><i class="bi bi-geo-alt text-muted"></i> @Html.DisplayFor(modelItem => item.Apiario.Nombre)</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
