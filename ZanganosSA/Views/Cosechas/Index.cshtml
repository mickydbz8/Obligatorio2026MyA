@model IEnumerable<ZanganosSA.Models.Cosecha>

@{
    ViewData["Title"] = "Cosechas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="bi bi-basket-fill text-success"></i> Cosechas</h1>
    <a asp-action="Create" class="btn btn-warning fw-bold"><i class="bi bi-plus-circle"></i> Nueva Cosecha</a>
</div>

<div class="table-responsive">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Fecha de Cosecha</th>
            <th>Peso Total Estimado (kg)</th>
            <th>Apiario</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FechaCosecha.ToString("dd/MM/yyyy")</td>
                <td><strong>@Html.DisplayFor(modelItem => item.PesoTotalEstimado) kg</strong></td>
                <td><i class="bi bi-geo-alt text-muted"></i> @Html.DisplayFor(modelItem => item.Apiario.Nombre)</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil"></i> Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye"></i> Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash"></i> Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
