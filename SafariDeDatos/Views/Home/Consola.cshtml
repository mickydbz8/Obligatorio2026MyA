@{
    ViewData["Title"] = "Consola SQL";
    var filas = ViewBag.Filas as List<Dictionary<string, object>>;
}
<h1 style="font-family: 'Outfit', sans-serif; color: #2b2b2b;">Consola SQL</h1>

<form method="post" style="margin-bottom: 1rem;">
    <textarea name="sql" rows="5" cols="80" placeholder="SELECT * FROM explorar('leon');">@ViewBag.Sql</textarea>
    <br />
    <button type="submit" style="margin-top: 0.5rem; padding: 0.5rem 1rem; background: linear-gradient(45deg, #0066ff, #33ccff); color: white; border: none; border-radius: 4px; cursor: pointer;">Ejecutar</button>
</form>

@if (filas != null)
{
    if (filas.Count == 0)
    {
        <p>La consulta no devolvió filas.</p>
    }
    else
    {
        <table border="1" cellpadding="4" style="border-collapse: collapse; width: 100%;">
            <thead style="background: rgba(0,102,255,0.1);">
                <tr>
                    @foreach (var columna in filas[0].Keys)
                    {
                        <th style="padding: 0.5rem;">@columna</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var fila in filas)
                {
                    <tr>
                        @foreach (var valor in fila.Values)
                        {
                            <td style="padding: 0.5rem;">@valor</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
}
