@model ZanganosSA.Models.Cosecha

@{
    ViewData["Title"] = "Editar Cosecha";
    var selectedColmenas = (List<int>)ViewBag.SelectedColmenas;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-pencil text-warning"></i> Editar Cosecha</h2>
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="FechaCosecha" class="form-label fw-bold">Fecha de Cosecha</label>
                    <input asp-for="FechaCosecha" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaCosecha" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="PesoTotalEstimado" class="form-label fw-bold">Peso Total Estimado (kg)</label>
                    <input asp-for="PesoTotalEstimado" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="PesoTotalEstimado" class="text-danger small"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="ApiarioId" class="form-label fw-bold">Apiario de Origen</label>
                    <select asp-for="ApiarioId" class="form-select" asp-items="ViewBag.ApiarioId"></select>
                    <span asp-validation-for="ApiarioId" class="text-danger small"></span>
                </div>

                <!-- Colmenas a cosechar (Filtrado Dinámico por JS) -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Colmenas Cosechadas</label>
                    <div id="colmenas-container" class="border rounded p-3 bg-white" style="max-height: 220px; overflow-y: auto;">
                        <p id="no-apiario-msg" class="text-muted small mb-0"><i class="bi bi-info-circle text-warning"></i> Por favor, selecciona un apiario para ver sus colmenas.</p>
                        @if (ViewBag.Colmenas != null)
                        {
                            foreach (var colmena in (List<ZanganosSA.Models.Colmena>)ViewBag.Colmenas)
                            {
                                bool isChecked = selectedColmenas != null && selectedColmenas.Contains(colmena.Id);
                                <div class="form-check colmena-option mb-2" data-apiario="@colmena.ApiarioId" style="display: none;">
                                    <input class="form-check-input colmena-checkbox" type="checkbox" name="selectedColmenas" value="@colmena.Id" id="colmena_@colmena.Id" @(isChecked ? "checked" : "")>
                                    <label class="form-check-label" for="colmena_@colmena.Id">
                                        <strong>@colmena.Identificador</strong> 
                                        <span class="text-muted small">(Estado: @colmena.EstadoGeneral | Reina: @colmena.EstadoReina)</span>
                                    </label>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <a asp-action="Index" class="btn-paginado-dorado"><i class="bi bi-arrow-left"></i> Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var apiarioSelect = document.getElementById("ApiarioId");
            var colmenaOptions = document.querySelectorAll(".colmena-option");
            var noApiarioMsg = document.getElementById("no-apiario-msg");

            function filterColmenas(keepChecked) {
                var selectedApiario = apiarioSelect.value;
                var visibleCount = 0;

                if (!selectedApiario) {
                    noApiarioMsg.innerHTML = '<i class="bi bi-info-circle text-warning"></i> Por favor, selecciona un apiario para ver sus colmenas.';
                    noApiarioMsg.style.display = "block";
                    colmenaOptions.forEach(function (opt) {
                        opt.style.display = "none";
                        if (!keepChecked) opt.querySelector(".colmena-checkbox").checked = false;
                    });
                    return;
                }

                colmenaOptions.forEach(function (opt) {
                    if (opt.getAttribute("data-apiario") === selectedApiario) {
                        opt.style.display = "block";
                        visibleCount++;
                    } else {
                        opt.style.display = "none";
                        if (!keepChecked) opt.querySelector(".colmena-checkbox").checked = false;
                    }
                });

                if (visibleCount === 0) {
                    noApiarioMsg.innerHTML = '<i class="bi bi-exclamation-triangle text-danger"></i> No hay colmenas registradas en este apiario.';
                    noApiarioMsg.style.display = "block";
                } else {
                    noApiarioMsg.style.display = "none";
                }
            }

            // On initial load, preserve already checked items even if apiario matches (they should match by default)
            filterColmenas(true);

            // On change, we can clear checked items of other apiarios to avoid cross-apiario records
            apiarioSelect.addEventListener("change", function() {
                filterColmenas(false);
            });
        });
    </script>
}
