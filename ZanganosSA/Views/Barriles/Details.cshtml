@model ZanganosSA.Models.Barril

@{
    ViewData["Title"] = "Detalles del Barril";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm p-4">
            <h2 class="mb-4"><i class="bi bi-eye text-warning"></i> Detalles del Barril</h2>
            <dl class="row">
                <dt class="col-sm-4 fw-bold">Código de Lote</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.CodigoLote)</dd>
                <dt class="col-sm-4 fw-bold">Peso Neto</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.PesoNeto) kg</dd>
                <dt class="col-sm-4 fw-bold">Fecha de Envasado</dt>
                <dd class="col-sm-8">@Model.FechaEnvasado.ToString("dd/MM/yyyy")</dd>
                <dt class="col-sm-4 fw-bold">Cosecha N°</dt>
                <dd class="col-sm-8">#@Html.DisplayFor(model => model.Cosecha.Id)</dd>
            </dl>
            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning fw-bold"><i class="bi bi-pencil"></i> Editar</a>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver al listado</a>
            </div>
        </div>
    </div>
</div>
